      "Euc: {a}\n",
      "Euo: {c}\n",
      "Source | (Target, Event), ...)\n",
      "('0', '1')  :  [(('2', '2'), a), (('1', '3'), b)]\n",
      "('2', '2')  :  [(('3', '4'), b)]\n",
      "('1', '3')  :  [(('3', '4'), a)]\n",
