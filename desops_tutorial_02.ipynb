      "Euo: set()\n",
      "Source | (Target, Event), ...)\n",
      "('1', 'A', 'eps')  :  [(('2', 'B', rN), rN), (('3', 'A', rE), rE)]\n",
      "('2', 'B', rN)  :  []\n",
      "('3', 'A', rE)  :  [(('3', 'A', 'eps'), rE, deleted : True)]\n",
      "('3', 'A', 'eps')  :  [(('4', 'B', rN), rN)]\n",
      "('4', 'B', rN)  :  []\n",
      "\n",
      "Probability of success for best attack strategy:  0.5\n"
     ]
    }
   ],
